# GHOST MARKETER v51.0 — Environment Variables Setup
# Copy this to .env and fill in your values

# ===================
# AI SERVICES
# ===================

# Groq API (Free tier - content generation)
# Get key: https://console.groq.com
GROQ_API_KEY=YOUR_GROQ_KEY_HERE

# HeyGen API (AI Video/Images)
# Get key: https://heygen.com
HEYGEN_API_KEY=YOUR_HEYGEN_KEY_HERE

# Replicate API (Stable Diffusion - image generation)
# Get key: https://replicate.com
REPLICATE_API_KEY=YOUR_REPLICATE_KEY_HERE

# ===================
# SOCIAL MEDIA
# ===================

# Twitter/X API v2
# Get keys: https://developer.twitter.com
TWITTER_BEARER=YOUR_TWITTER_BEARER
TWITTER_API_KEY=YOUR_TWITTER_API_KEY
TWITTER_API_SECRET=YOUR_TWITTER_API_SECRET
TWITTER_ACCESS_TOKEN=YOUR_TWITTER_ACCESS_TOKEN
TWITTER_ACCESS_SECRET=YOUR_TWITTER_ACCESS_SECRET

# ===================
# WORDPRESS
# ===================

# Get from: WordPress Admin → Users → Application Passwords
# Format: username|app_password
WORDPRESS_APP_PASSWORD=your_wordpress_password_here
WORDPRESS_URL=https://your-site.com

# ===================
# NOTIFICATIONS
# ===================

TELEGRAM_BOT=8720583469:AAFwEF2yr6EjHvIV2Htwu4QG5uBS-cdBPeE
TELEGRAM_CHAT=1707504118

# ===================
# HOW TO RUN
# ===================

# Method 1: Export env vars
# export $(cat .env | xargs) && python3 GHOST_MARKETER.py

# Method 2: Use setup wizard
# python3 SETUP_WIZARD.py

# Method 3: Direct run
# python3 GHOST_MARKETER.py https://mysite.com username|password
